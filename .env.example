# Optional: local development proxy target for Vite dev server /sub2api.
# Example: https://your-sub2api.example.com
VITE_SUB2API_PROXY_TARGET=http://127.0.0.1:18080

# Optional: Docker/Nginx runtime proxy target for production /sub2api.
# Set this to your deployed image API service base URL on VPS.
SUB2API_PROXY_TARGET=https://your-sub2api.example.com
