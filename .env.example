# Miastra Studio 根目录环境变量示例
#
# 使用方式：
# 1. 复制为项目根目录 `.env`
# 2. 前端 Vite 与服务端 Fastify 默认都会读取根目录 `.env`
# 3. 如果只想覆盖服务端变量，可额外创建 `server/.env`

########################################
# 前端开发代理（仅 `npm run dev` 使用）
########################################

# Vite 开发服务器中的 /api 代理目标，通常指向本地 Fastify
VITE_API_PROXY_TARGET=http://127.0.0.1:18081

# Vite 开发服务器中的 /sub2api 代理目标，通常指向外部 Provider
VITE_SUB2API_PROXY_TARGET=http://127.0.0.1:18080

########################################
# 服务端运行
########################################

# Fastify 监听端口
PORT=18081

# 存储后端：json 或 postgres
SERVER_STORE_BACKEND=json

# 当 SERVER_STORE_BACKEND=postgres 时必须提供
DATABASE_URL=postgresql://miastra:miastra@127.0.0.1:5432/miastra

########################################
# Provider / 任务相关
########################################

# 当用户 Provider API URL 留空时，服务端代理回退到这个地址
PROVIDER_UPSTREAM_ORIGIN=http://127.0.0.1:18080

# 当前代码中 generation worker 为轻量保留实现，通常无需调整
GENERATION_WORKER_INTERVAL_MS=1200
GENERATION_WORKER_CONCURRENCY=2
GENERATION_PROXY_ORIGIN=http://127.0.0.1:5173

########################################
# 认证 / Billing
########################################

# 生产环境必须设置强随机值
AUTH_JWT_SECRET=change-me
RESET_JWT_SECRET=change-me-too

# disabled 或 debug
# 生产环境会强制关闭 debug token 暴露
AUTH_PASSWORD_RESET_MODE=debug

# disabled / mock / real
# 生产环境默认会回退为 disabled；mock 仅适合演示环境
BILLING_MODE=mock

########################################
# 前端静态容器 / Nginx（`docker compose up -d --build` 使用）
########################################

NGINX_PORT=80
CLIENT_MAX_BODY_SIZE=25m
SUB2API_PROXY_TARGET=http://127.0.0.1:18080
PROXY_CONNECT_TIMEOUT=60s
PROXY_SEND_TIMEOUT=600s
PROXY_READ_TIMEOUT=600s
SEND_TIMEOUT=600s

########################################
# Postgres 容器默认参数（`docker compose -f docker-compose.db.yml up -d` 使用）
########################################

POSTGRES_DB=miastra
POSTGRES_USER=miastra
POSTGRES_PASSWORD=miastra
POSTGRES_PORT=5432
