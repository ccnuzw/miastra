# Miastra Studio 环境变量示例
#
# 用法：
# 1. 复制为项目根目录 `.env`
# 2. 根目录 `.env` 同时用于前端开发代理和服务端运行时
# 3. `server/.env` 仅在需要覆盖服务端变量时再创建

########################################
# 服务端运行（必填）
########################################

# Fastify 监听端口
PORT=18081

# 当前云端项目默认使用 Postgres
SERVER_STORE_BACKEND=postgres

# 指向可访问的 Postgres 实例
DATABASE_URL=postgresql://miastra:miastra@127.0.0.1:5432/miastra

########################################
# 认证与访问控制（必填）
########################################

# 生产环境必须替换为强随机值
AUTH_JWT_SECRET=replace-with-strong-random-value
RESET_JWT_SECRET=replace-with-another-strong-random-value

########################################
# 服务端运行（常用可选）
########################################

# disabled / mock / real
BILLING_MODE=disabled

# Provider API URL 留空时，服务端统一回退到这个默认上游
PROVIDER_UPSTREAM_ORIGIN=https://api.openai.com

# generation worker 调度参数
GENERATION_WORKER_INTERVAL_MS=1200
GENERATION_WORKER_CONCURRENCY=2
GENERATION_PROXY_ORIGIN=http://127.0.0.1:5173

########################################
# 前端开发代理（仅 `npm run dev` 使用）
########################################

VITE_API_PROXY_TARGET=http://127.0.0.1:18081
VITE_SUB2API_PROXY_TARGET=http://127.0.0.1:18080

########################################
# 前端静态容器 / Nginx
# 仅在使用仓库内 Dockerfile 或 docker-compose.yml 时需要
########################################

NGINX_PORT=80
CLIENT_MAX_BODY_SIZE=25m
SUB2API_PROXY_TARGET=http://127.0.0.1:18080
PROXY_CONNECT_TIMEOUT=60s
PROXY_SEND_TIMEOUT=600s
PROXY_READ_TIMEOUT=600s
SEND_TIMEOUT=600s
