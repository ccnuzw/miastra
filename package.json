{
  "name": "miastra-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:server": "npm --prefix server run build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:server": "npm --prefix server run typecheck",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "test:smoke": "npm run test:smoke:client && npm run test:smoke:server",
    "test:smoke:client": "vitest run src/shared/http/client.test.ts src/shared/storage/browserDatabase.test.ts src/shared/utils/download.metadata.test.ts src/shared/utils/download.zip.test.ts src/features/works/works.storage.test.ts src/features/works/useWorksGallery.test.ts",
    "test:smoke:server": "npm --prefix server run test:smoke",
    "test": "vitest run && npm --prefix server test",
    "test:watch": "vitest",
    "test:client": "vitest run",
    "test:server": "npm --prefix server test",
    "test:regression": "npm run test:client && npm run test:server",
    "release:check": "npm run test:smoke && npm run test:regression && npm run build && npm run build:server"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.13",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.6.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
