{
  "name": "miastra-server",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "NODE_ENV=test SERVER_STORE_BACKEND=json vitest run --maxWorkers 1",
    "test:smoke": "NODE_ENV=test SERVER_STORE_BACKEND=json vitest run --maxWorkers 1 src/server.test.ts src/release.regression.test.ts",
    "test:watch": "vitest",
    "db:init": "tsx scripts/db-init.ts",
    "db:bootstrap": "tsx scripts/db-bootstrap.ts",
    "db:reset": "tsx scripts/db-reset.ts",
    "db:seed": "tsx scripts/db-seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.6.1",
    "fastify": "^5.2.1",
    "jose": "^5.9.6",
    "pg": "^8.16.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.15.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  }
}
